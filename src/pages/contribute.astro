---
import Layout from "../layouts/Layout.astro";

// Code snippets (rendered as literal text — kept out of the template to avoid
// brace parsing). Sources: statlib README §1 + §3.
const lakeSnippet = `[[require]]
name = "statlib"
git = "https://github.com/statopia/statlib.git"
rev = "main"`;

const buildSnippet = `lake update          # fetch Mathlib
lake exe cache get   # download Mathlib .olean cache
lake build           # build the library`;

const importSnippet = `import Statlib                            -- full library entry point

-- or import only the topic you need (faster builds):
import Statlib.StatFoundation.Convergence
import Statlib.HighDim.Concentration`;

// Construction workflow — statlib README §3 (Construction Method).
const workflow = [
  "Start from the smallest useful theorem or definition.",
  "Put shared concepts in the vocabulary layer only when they are genuinely reusable.",
  "Keep imports narrow — prefer topic-level dependencies, avoid broad root imports in leaf files.",
  "Build the target module locally before expanding the proof.",
  "Run lake build Statlib before submitting the change.",
  "If the change creates a meaningful theorem chain, regenerate the proof narratives and inspect the dependency graph.",
];

// Contribution rules — statlib README §3 (Contribution Rules).
const rules = [
  "Depend on Mathlib only.",
  "Keep declarations and files easy to inspect.",
  "Use clear namespaces under Statlib.<Area>.",
  "Avoid unnecessary cross-topic imports.",
  "Document any new axiom with its mathematical content, blocker, and intended replacement.",
  "Do not introduce sorry into the core library unless maintainers have accepted a staged/WIP contribution.",
];

// How to join — statlib README §3 (How to Join).
const ways = [
  {
    title: "Improve existing material",
    body: "Simplify proofs, remove lint warnings, sharpen statements without changing meaning, replace axiom dependencies with proved lemmas, improve documentation and proof narratives.",
  },
  {
    title: "Fill gaps",
    body: "Add missing definitions, assumptions, lemmas, and standard theorem variants that make existing probability, statistics, concentration, convergence, and high-dimensional modules easier to use.",
  },
  {
    title: "Add new domain areas",
    body: "Create new topic files or folders for fields not yet well covered — nonparametric and semiparametric statistics, causal inference, empirical process theory, information-theoretic learning, and PAC / generalization theory are especially valuable.",
  },
];
---

<Layout title="Contribute" description="How to use statlib as a dependency and contribute new formalized material.">
  <article class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink">Contribute</h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-soft">
      statlib grows by contribution — new definitions, lemmas, theorem chains, and
      whole domain areas. This page covers how to build it, how material is added,
      and where help is most valuable.
    </p>

    <!-- Get started -->
    <div class="mt-14 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">1</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Get started</h2>
    </div>
    <p class="mt-3 leading-relaxed text-ink-soft">
      statlib targets Lean <code class="font-mono text-sm">v4.28.0-rc1</code> and the
      matching Mathlib. Add it as a Lake dependency in your
      <code class="font-mono text-sm">lakefile.toml</code>:
    </p>
    <pre class="mt-4 overflow-x-auto rounded-lg bg-ink p-4 text-sm leading-relaxed text-paper"><code>{lakeSnippet}</code></pre>
    <p class="mt-4 leading-relaxed text-ink-soft">Then fetch and build:</p>
    <pre class="mt-4 overflow-x-auto rounded-lg bg-ink p-4 text-sm leading-relaxed text-paper"><code>{buildSnippet}</code></pre>
    <p class="mt-4 leading-relaxed text-ink-soft">Import the whole library, or just the topic you need:</p>
    <pre class="mt-4 overflow-x-auto rounded-lg bg-ink p-4 text-sm leading-relaxed text-paper"><code>{importSnippet}</code></pre>
    <p class="mt-4 leading-relaxed text-ink-soft">
      Working inside the repository, the recommended local check is
      <code class="rounded bg-accent-soft px-1.5 py-0.5 font-mono text-sm text-accent">lake build Statlib</code>.
    </p>

    <!-- Construction method -->
    <div class="mt-16 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">2</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Construction method</h2>
    </div>
    <p class="mt-3 leading-relaxed text-ink-soft">
      New material is added bottom-up, kept narrow, and verified before it grows:
    </p>
    <ol class="mt-6 space-y-4">
      {
        workflow.map((w, i) => (
          <li class="flex gap-4">
            <span class="font-mono text-sm font-semibold text-accent">{String(i + 1).padStart(2, "0")}</span>
            <span class="leading-relaxed text-ink-soft">{w}</span>
          </li>
        ))
      }
    </ol>

    <!-- Contribution rules -->
    <div class="mt-16 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">3</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Contribution rules</h2>
    </div>
    <ul class="mt-6 space-y-2">
      {
        rules.map((r) => (
          <li class="flex gap-3 text-ink-soft">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" />
            <span class="leading-relaxed">{r}</span>
          </li>
        ))
      }
    </ul>

    <!-- How to join -->
    <div class="mt-16 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">4</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">How to join</h2>
    </div>
    <p class="mt-3 leading-relaxed text-ink-soft">Useful contributions usually fall into three kinds:</p>
    <div class="mt-6 space-y-px overflow-hidden rounded-lg border border-line bg-line">
      {
        ways.map((w, i) => (
          <div class="bg-surface p-5">
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-xs text-faint">{i + 1}</span>
              <h3 class="font-serif text-lg font-semibold text-ink">{w.title}</h3>
            </div>
            <p class="mt-1 pl-6 leading-relaxed text-ink-soft">{w.body}</p>
          </div>
        ))
      }
    </div>
    <p class="mt-6 leading-relaxed text-ink-soft">
      For a large addition, propose the mathematical statement, where it should
      live in the module tree, what it depends on, whether it introduces new
      vocabulary, and whether it needs any temporary axiom — then open a focused
      branch and submit a PR that runs <code class="font-mono text-sm">lake build Statlib</code>.
    </p>

    <aside class="mt-12 rounded-lg border border-dashed border-line bg-surface p-6">
      <p class="text-sm leading-relaxed text-ink-soft">
        The statlib repository is currently private. If you'd like to contribute or
        use it, contact the maintainers for access — public release and full
        contribution guidelines will follow.
      </p>
    </aside>
  </article>
</Layout>
