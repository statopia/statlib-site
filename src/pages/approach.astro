---
import Layout from "../layouts/Layout.astro";

// Architecture philosophy — statlib README §2.
const principles = [
  "Prefer reusable definitions and theorem statements over one-off encodings.",
  "Keep topic boundaries clear enough that users can import only what they need.",
  "Choose representative results that clarify the structure of a field.",
  "Avoid long proof developments whose final statements are hard to apply elsewhere.",
  "When adding specialized results, expose the assumptions, intermediate lemmas, and vocabulary that make them reusable.",
];

// Construction workflow — statlib README §3 (Construction Method).
const workflow = [
  "Start from the smallest useful theorem or definition.",
  "Put shared concepts in the vocabulary layer only when they are genuinely reusable.",
  "Keep imports narrow — prefer topic-level dependencies, avoid broad root imports in leaf files.",
  "Build the target module locally before expanding the proof.",
  "Run lake build Statlib before submitting the change.",
  "If the change creates a meaningful theorem chain, regenerate the proof narratives and inspect the dependency graph.",
];

// Near-term priorities — statlib README §3 (Near-Term Priorities).
const priorities = [
  "Clean up lint/style warnings in existing modules.",
  "Discharge or replace the remaining named axiom where feasible.",
  "Strengthen high-dimensional concentration, covariance, RIP, spectral perturbation, and regression chains.",
  "Keep proof narratives and architecture diagrams useful as the dependency graph grows.",
];
---

<Layout title="Approach" description="statlib's architecture philosophy, construction method, and status.">
  <article class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink">Design &amp; approach</h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-soft">
      statlib is organized so that material is usable, not just present. Its
      purpose is to support future formalization work — not to formalize one
      textbook or collect impressive but hard-to-use isolated results. Each topic
      aims to contain representative material exposed in a form later work can
      build on.
    </p>

    <!-- Architecture -->
    <div class="mt-14 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">1</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Architecture</h2>
    </div>
    <p class="mt-3 leading-relaxed text-ink-soft">
      The library is organized by statistical and machine-learning
      <span class="font-medium text-ink">domains</span> — you find material by
      mathematical topic, not by the source a theorem came from. Inside each area,
      the structure has two complementary parts:
    </p>
    <div class="mt-6 grid gap-px overflow-hidden rounded-lg border border-line bg-line sm:grid-cols-2">
      <div class="bg-surface p-5">
        <h3 class="font-serif text-lg font-semibold text-ink">Concepts &amp; structures</h3>
        <p class="mt-1 text-sm leading-relaxed text-ink-soft">
          Names for the objects, assumptions, predicates, models, classes, and
          reusable vocabulary specific to that area — easy to import and reuse.
        </p>
      </div>
      <div class="bg-surface p-5">
        <h3 class="font-serif text-lg font-semibold text-ink">Results &amp; proofs</h3>
        <p class="mt-1 text-sm leading-relaxed text-ink-soft">
          Theorems, lemmas, properties, and proof infrastructure for the main
          subclasses and standard results in that area.
        </p>
      </div>
    </div>
    <ul class="mt-6 space-y-2">
      {
        principles.map((p) => (
          <li class="flex gap-3 text-ink-soft">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60" />
            <span class="leading-relaxed">{p}</span>
          </li>
        ))
      }
    </ul>

    <!-- Construction method -->
    <div class="mt-16 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">2</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Construction method</h2>
    </div>
    <p class="mt-3 leading-relaxed text-ink-soft">
      New material is added bottom-up, kept narrow, and verified before it grows:
    </p>
    <ol class="mt-6 space-y-4">
      {
        workflow.map((w, i) => (
          <li class="flex gap-4">
            <span class="font-mono text-sm font-semibold text-accent">{String(i + 1).padStart(2, "0")}</span>
            <span class="leading-relaxed text-ink-soft">{w}</span>
          </li>
        ))
      }
    </ol>

    <!-- Current status -->
    <div class="mt-16 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">3</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Current status</h2>
    </div>
    <p class="mt-3 leading-relaxed text-ink-soft">
      <code class="rounded bg-accent-soft px-1.5 py-0.5 font-mono text-sm text-accent">lake build Statlib</code>
      builds cleanly. The core tree has <span class="font-medium text-ink">zero <code class="font-mono text-sm">sorry</code></span>;
      a single named axiom remains — a matrix Lieb trace step in high-dimensional
      concentration — documented with its intended replacement path. The library
      depends on <span class="font-medium text-ink">Mathlib only</span>.
    </p>
    <p class="mt-6 text-sm font-medium text-ink">Near-term priorities</p>
    <ul class="mt-2 space-y-2">
      {
        priorities.map((p) => (
          <li class="flex gap-3 text-ink-soft">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-faint" />
            <span class="leading-relaxed">{p}</span>
          </li>
        ))
      }
    </ul>

    <aside class="mt-16 rounded-lg border border-line bg-surface p-6">
      <h2 class="font-serif text-lg font-semibold text-ink">A technical report is coming</h2>
      <p class="mt-2 text-sm text-ink-soft">
        A report on how statlib is constructed and verified is in preparation.
      </p>
      <a href="/report" class="mt-4 inline-block text-sm font-semibold text-accent hover:underline">
        Go to the technical report →
      </a>
    </aside>
  </article>
</Layout>
