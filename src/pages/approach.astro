---
import Layout from "../layouts/Layout.astro";

// The pipeline stages — EDIT to match the real method described in the report.
const steps = [
  {
    n: "01",
    title: "Source the statement",
    body: "Theorems are taken from the statistics & probability literature and rendered into a precise mathematical specification.",
  },
  {
    n: "02",
    title: "Formalize in Lean",
    body: "The specification is translated into a Lean 4 statement against Mathlib, with the signature locked so the target can't be silently weakened.",
  },
  {
    n: "03",
    title: "Prove automatically",
    body: "An automated prover decomposes the goal, searches for tactics, and fills the proof — iterating against the Lean compiler until it closes.",
  },
  {
    n: "04",
    title: "Verify & integrity-check",
    body: "Independent checks confirm the final statement still matches the original spec before it enters the main library tree.",
  },
];
---

<Layout title="Approach" description="How statlib's proofs are formalized and machine-checked.">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-ink">The approach</h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-soft">
      statlib is built by an automated formalize-and-prove pipeline. Every result
      is machine-checked end to end — the goal is a library you can trust because
      the compiler, not a person, signs off on each proof.
    </p>

    <ol class="mt-12 space-y-8">
      {
        steps.map((s) => (
          <li class="flex gap-5">
            <span class="font-mono text-sm font-semibold text-accent">{s.n}</span>
            <div>
              <h2 class="font-semibold text-ink">{s.title}</h2>
              <p class="mt-1 leading-relaxed text-ink-soft">{s.body}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="mt-16 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <h2 class="font-semibold text-ink">Want the full method?</h2>
      <p class="mt-2 text-sm text-ink-soft">
        A technical report covering the pipeline, evaluation, and integrity
        guarantees is in preparation.
      </p>
      <a href="/report" class="mt-4 inline-block text-sm font-semibold text-accent hover:underline">
        Go to the technical report →
      </a>
    </div>
  </section>
</Layout>
