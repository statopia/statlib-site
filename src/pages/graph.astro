---
import Layout from "../layouts/Layout.astro";
import { graphStats, graphIndexUrl, graphBase, featured } from "../data/graph";
---

<Layout
  title="Knowledge Graph"
  description="Proof-dependency diagrams over the statlib corpus — reconstructed narratives across thousands of declarations."
>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink">Knowledge graph</h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-soft">
      Each proved result in statlib rests on a chain of supporting declarations.
      These <span class="font-serif font-semibold text-ink">proof narratives</span>
      reconstruct those chains as dependency graphs over the atomic Lean corpus —
      reading views, with no files moved.
    </p>

    <!-- Stats -->
    <div class="mt-10 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-line bg-line sm:grid-cols-4">
      {
        graphStats.map((s) => (
          <div class="bg-surface px-5 py-6 text-center">
            <div class="font-serif text-2xl font-semibold text-ink">{s.value}</div>
            <div class="mt-1 text-xs text-ink-soft">{s.label}</div>
          </div>
        ))
      }
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={graphIndexUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent/90"
      >
        Open the full diagram index →
      </a>
    </div>

    <!-- Featured developments -->
    <div class="mt-16 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">1</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">
        Substantial proof developments
      </h2>
    </div>
    <p class="mt-3 max-w-2xl text-ink-soft">
      A few of the largest dependency graphs. Click to open the full diagram.
    </p>

    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((f) => (
          <a
            href={`${graphBase}/${f.svg}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col overflow-hidden rounded-lg border border-line bg-surface transition hover:border-accent/50 hover:shadow-sm"
          >
            <div class="flex h-40 items-center justify-center overflow-hidden border-b border-line bg-paper p-3">
              <img
                src={`${graphBase}/${f.svg}`}
                alt={`Dependency graph for ${f.name}`}
                loading="lazy"
                class="max-h-full max-w-full object-contain opacity-90 transition group-hover:opacity-100"
              />
            </div>
            <div class="p-4">
              <p class="font-mono text-xs uppercase tracking-wide text-accent">{f.topic}</p>
              <h3 class="mt-1 truncate font-mono text-sm font-medium text-ink" title={f.name}>
                {f.name}
              </h3>
              <p class="mt-1 text-xs text-faint">{f.decls} declarations</p>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Inline browse -->
    <div class="mt-16 flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">2</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Browse all diagrams</h2>
    </div>
    <p class="mt-3 max-w-2xl text-ink-soft">
      The full index of proof narratives, embedded below — or
      <a href={graphIndexUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">open it in a new tab</a>.
    </p>
    <div class="mt-6 overflow-hidden rounded-lg border border-line bg-surface">
      <iframe
        src={graphIndexUrl}
        title="Proof-narrative diagram index"
        loading="lazy"
        class="h-[640px] w-full"
      ></iframe>
    </div>

    <p class="mt-6 text-xs leading-relaxed text-faint">
      Note: nodes inside each diagram link to source files via local editor
      (<code class="font-mono">vscode://</code>) URLs — useful to the maintainers, inert for
      public visitors.
    </p>
  </section>
</Layout>
