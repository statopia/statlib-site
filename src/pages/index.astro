---
import Layout from "../layouts/Layout.astro";
import { site, stats } from "../data/site";
import { topics } from "../data/theorems";

// A few highlights pulled from the catalog for the landing page.
const highlights = topics
  .flatMap((t) => t.theorems.map((th) => ({ ...th, topic: t.title })))
  .filter((th) => th.status === "proved")
  .slice(0, 4);
---

<Layout>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-gray-200 bg-grid">
    <div class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
      <p class="font-mono text-sm font-medium text-accent">{site.org} · Lean 4 · Mathlib</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-bold tracking-tight text-ink sm:text-6xl">
        {site.tagline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft">
        {site.description}
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/library"
          class="rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-accent/90"
        >
          Browse the library
        </a>
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-gray-300 bg-white px-5 py-3 text-sm font-semibold text-ink transition hover:bg-gray-50"
        >
          View on GitHub →
        </a>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="border-b border-gray-200 bg-white">
    <div class="mx-auto grid max-w-6xl grid-cols-1 divide-y divide-gray-200 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
      {
        stats.map((s) => (
          <div class="px-6 py-8 text-center">
            <div class="font-mono text-3xl font-bold text-ink">{s.value}</div>
            <div class="mt-1 text-sm text-ink-soft">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- What it is -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <h2 class="text-2xl font-bold tracking-tight text-ink">What's inside</h2>
    <p class="mt-3 max-w-2xl text-ink-soft">
      Every entry is a real statement from statistics or probability, formalized
      and proved in Lean 4 so that the proof is checked by the compiler — no gaps,
      no hand-waving.
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        topics.map((t) => (
          <a
            href={`/library#${t.id}`}
            class="group rounded-xl border border-gray-200 p-6 transition hover:border-accent/50 hover:shadow-sm"
          >
            <h3 class="font-semibold text-ink group-hover:text-accent">{t.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{t.summary}</p>
            <p class="mt-4 font-mono text-xs text-gray-400">
              {t.theorems.length} entries →
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Highlights -->
  {
    highlights.length > 0 && (
      <section class="border-t border-gray-200 bg-gray-50">
        <div class="mx-auto max-w-6xl px-6 py-20">
          <h2 class="text-2xl font-bold tracking-tight text-ink">Selected results</h2>
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {highlights.map((th) => (
              <div class="rounded-xl border border-gray-200 bg-white p-6">
                <p class="font-mono text-xs text-accent">{th.topic}</p>
                <h3 class="mt-1 font-semibold text-ink">{th.name}</h3>
                <p class="mt-2 text-sm text-ink-soft">{th.blurb}</p>
                {th.lean && (
                  <code class="mt-3 block truncate font-mono text-xs text-gray-400">
                    {th.lean}
                  </code>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-6 py-20 text-center">
    <h2 class="text-2xl font-bold tracking-tight text-ink">
      How the proofs get built
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-ink-soft">
      statlib is produced by an automated formalize-and-prove pipeline. A
      technical report describing the method is on the way.
    </p>
    <div class="mt-8 flex justify-center gap-4">
      <a href="/approach" class="rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-white transition hover:bg-accent/90">
        Read the approach
      </a>
      <a href="/report" class="rounded-lg border border-gray-300 px-5 py-3 text-sm font-semibold text-ink transition hover:bg-gray-50">
        Technical report
      </a>
    </div>
  </section>
</Layout>
