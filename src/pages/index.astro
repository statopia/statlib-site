---
import Layout from "../layouts/Layout.astro";
import Math from "../components/Math.astro";
import { site, stats } from "../data/site";
import { topics } from "../data/theorems";

// A few proved highlights pulled from the catalog for the landing page.
const highlights = topics
  .flatMap((t) => t.theorems.map((th) => ({ ...th, topic: t.title })))
  .filter((th) => th.status === "proved" && th.latex)
  .slice(0, 4);
---

<Layout>
  <!-- Hero -->
  <section>
    <div class="mx-auto max-w-5xl px-6 pt-20 pb-16 sm:pt-28">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">
        {site.org} · Lean 4 · Mathlib
      </p>
      <h1 class="mt-5 max-w-3xl font-serif text-4xl font-semibold leading-[1.12] tracking-tight text-ink sm:text-5xl">
        {site.tagline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft">
        <span class="font-serif font-semibold text-ink">Abstract.</span>
        {site.description} Every entry is checked end to end by the Lean compiler —
        no gaps, no hand-waving.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a
          href="/library"
          class="rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent/90"
        >
          Browse the library
        </a>
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md border border-line bg-surface px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-accent-soft/50"
        >
          View on GitHub →
        </a>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="border-y border-line bg-surface">
    <div class="mx-auto grid max-w-5xl grid-cols-1 divide-y divide-line sm:grid-cols-3 sm:divide-x sm:divide-y-0">
      {
        stats.map((s) => (
          <div class="px-6 py-7 text-center">
            <div class="font-serif text-3xl font-semibold text-ink">{s.value}</div>
            <div class="mt-1 text-sm text-ink-soft">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- What's inside -->
  <section class="mx-auto max-w-5xl px-6 py-20">
    <div class="flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">1</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">What's inside</h2>
    </div>
    <p class="mt-3 max-w-2xl text-ink-soft">
      statlib is organized by domain. Each area provides reusable definitions and
      representative theorems — chosen to clarify the structure of a field and to
      be built on, not one-off encodings — all formalized against Mathlib.
    </p>

    <div class="mt-10 grid gap-px overflow-hidden rounded-lg border border-line bg-line sm:grid-cols-2">
      {
        topics.map((t, i) => (
          <a
            href={`/library#${t.id}`}
            class="group bg-surface p-6 transition hover:bg-accent-soft/40"
          >
            <div class="flex items-baseline gap-2">
              <span class="font-mono text-xs text-faint">1.{i + 1}</span>
              <h3 class="font-serif text-lg font-semibold text-ink group-hover:text-accent">
                {t.title}
              </h3>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{t.summary}</p>
            <p class="mt-4 font-mono text-xs text-faint">{t.theorems.length} entries →</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Selected results -->
  {
    highlights.length > 0 && (
      <section class="border-t border-line bg-surface">
        <div class="mx-auto max-w-5xl px-6 py-20">
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-sm text-faint">2</span>
            <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">
              Selected results
            </h2>
          </div>
          <div class="mt-8 grid gap-5 sm:grid-cols-2">
            {highlights.map((th) => (
              <figure class="rounded-lg border border-line p-6">
                <figcaption class="font-mono text-xs uppercase tracking-wide text-accent">
                  {th.topic}
                </figcaption>
                <h3 class="mt-1 font-serif text-lg font-semibold text-ink">{th.name}</h3>
                <div class="mt-3 overflow-x-auto text-ink">
                  <Math expr={th.latex!} display />
                </div>
                <p class="mt-3 text-sm text-ink-soft">{th.blurb}</p>
                {th.lean && (
                  <code class="mt-3 block truncate font-mono text-xs text-faint">{th.lean}</code>
                )}
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="mx-auto max-w-5xl px-6 py-20 text-center">
    <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">
      Design &amp; construction
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-ink-soft">
      statlib aims to fill a foundation gap — reusable, machine-checked
      infrastructure for statistics and machine learning, built only on Mathlib.
      A technical report on its design and construction method is in preparation.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/approach" class="rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent/90">
        Read the approach
      </a>
      <a href="/report" class="rounded-md border border-line bg-surface px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-accent-soft/50">
        Technical report
      </a>
    </div>
  </section>
</Layout>
