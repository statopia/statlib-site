---
import Layout from "../layouts/Layout.astro";
import Math from "../components/Math.astro";
import { site, stats } from "../data/site";
import { topics } from "../data/theorems";
import { modules } from "../data/modules";

// Curated flagship results to feature on the landing page — chosen to span both
// modules and show range. Referenced by Lean id and resolved from the catalog so
// statements stay single-sourced in theorems.ts.
const flagship = [
  "lindeberg_feller_central_limit_theorem", // StatFoundation limit theorem
  "bernstein_sum_meas_ge_le_exp", // StatFoundation concentration
  "mcdiarmid_meas_ge_le_exp", // StatFoundation bounded differences
  "covering_number_euclidean_ball", // HighDim geometry
  "sampleCovariance_concentration", // HighDim covariance
  "lasso_oracle_prediction", // HighDim regression
];
const byLean = new Map(
  topics.flatMap((t) => t.theorems.map((th) => [th.lean, { ...th, topic: t.title }])),
);
const highlights = flagship
  .map((l) => byLean.get(l))
  .filter((th) => th !== undefined && th.latex);

function formatDeclarationCounts(topic: (typeof topics)[number]) {
  const counts = topic.declarationCounts;
  if (!counts) return `${topic.theorems.length} entries`;
  return `${counts.theorems} thm · ${counts.lemmas} lem`;
}
---

<Layout>
  <!-- Hero -->
  <section>
    <div class="mx-auto max-w-5xl px-6 pt-20 pb-16 sm:pt-28">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">
        {site.org} · Lean 4 · Mathlib
      </p>
      <h1 class="mt-5 max-w-3xl font-serif text-4xl font-semibold leading-[1.12] tracking-tight text-ink sm:text-5xl">
        {site.tagline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft">
        <span class="font-serif font-semibold text-ink">Abstract.</span>
        {site.description} Every entry is checked end to end by the Lean compiler —
        no gaps, no hand-waving.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a
          href="/library"
          class="rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent/90"
        >
          Browse the library
        </a>
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md border border-line bg-surface px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-accent-soft/50"
        >
          View on GitHub →
        </a>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="border-y border-line bg-surface">
    <div class="mx-auto grid max-w-5xl grid-cols-1 divide-y divide-line sm:grid-cols-2 sm:divide-x sm:divide-y-0">
      {
        stats.map((s) => (
          <div class="px-6 py-7 text-center">
            <div class="font-serif text-3xl font-semibold text-ink">{s.value}</div>
            <div class="mt-1 text-sm text-ink-soft">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- What's inside -->
  <section class="mx-auto max-w-5xl px-6 py-20">
    <div class="flex items-baseline gap-3">
      <span class="font-mono text-sm text-faint">1</span>
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">What's inside</h2>
    </div>
    <p class="mt-3 max-w-2xl text-ink-soft">
      statlib is built in two modules, each a tree of topic areas formalized
      against Mathlib. Today the work centers on these two boards:
    </p>

    <div class="mt-10 space-y-10">
      {
        modules.map((m, mi) => {
          const mTopics = m.topicIds
            .map((id) => topics.find((t) => t.id === id))
            .filter((t) => t !== undefined);
          return (
            <div class="rounded-xl border border-line bg-surface p-6 sm:p-8">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <span class="font-mono text-sm text-faint">1.{mi + 1}</span>
                <h3 class="font-serif text-xl font-semibold text-ink">{m.title}</h3>
                <code class="font-mono text-xs text-accent">{m.lean}</code>
              </div>
              <p class="mt-2 max-w-3xl text-sm leading-relaxed text-ink-soft">{m.summary}</p>

              <div class="mt-5 grid gap-px overflow-hidden rounded-lg border border-line bg-line sm:grid-cols-2">
                {mTopics.map((t) => (
                  <a
                    href={`/library#${t!.id}`}
                    class="group bg-surface p-4 transition hover:bg-accent-soft/40"
                  >
                    <div class="flex items-baseline justify-between gap-2">
                      <h4 class="font-serif font-semibold text-ink group-hover:text-accent">
                        {t!.title}
                      </h4>
                      <span class="shrink-0 font-mono text-xs text-faint">
                        {formatDeclarationCounts(t!)}
                      </span>
                    </div>
                    <p class="mt-1 text-sm leading-relaxed text-ink-soft">{t!.summary}</p>
                  </a>
                ))}
              </div>

              <p class="mt-4 text-sm text-ink-soft">
                <span class="font-medium text-ink">Roadmap.</span> {m.roadmap}
              </p>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- Selected results -->
  {
    highlights.length > 0 && (
      <section class="border-t border-line bg-surface">
        <div class="mx-auto max-w-5xl px-6 py-20">
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-sm text-faint">2</span>
            <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">
              Selected results
            </h2>
          </div>
          <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {highlights.map((th) => (
              <figure class="flex flex-col rounded-lg border border-line p-6">
                <figcaption class="font-mono text-xs uppercase tracking-wide text-accent">
                  {th!.topic}
                </figcaption>
                <h3 class="mt-1 font-serif text-lg font-semibold text-ink">{th!.name}</h3>
                <div class="mt-3 overflow-x-auto text-ink">
                  <Math expr={th!.latex!} display />
                </div>
                <p class="mt-3 text-sm text-ink-soft">{th!.blurb}</p>
                {th!.lean && (
                  <code class="mt-3 block truncate font-mono text-xs text-faint">{th!.lean}</code>
                )}
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="mx-auto max-w-5xl px-6 py-20 text-center">
    <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">
      Built to be reused — and extended
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-ink-soft">
      statlib aims to fill a foundation gap: reusable, machine-checked
      infrastructure for statistics and machine learning, built only on Mathlib.
      Read how it's designed, or help extend it.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/about" class="rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent/90">
        About statlib
      </a>
      <a href="/contribute" class="rounded-md border border-line bg-surface px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-accent-soft/50">
        Contribute
      </a>
    </div>
  </section>
</Layout>
