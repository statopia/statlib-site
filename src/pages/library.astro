---
import Layout from "../layouts/Layout.astro";
import StatusBadge from "../components/StatusBadge.astro";
import Math from "../components/Math.astro";
import TreeNode from "../components/TreeNode.astro";
import { topics } from "../data/theorems";
import { modules } from "../data/modules";
import { libraryTree } from "../data/tree";
import { site } from "../data/site";

// Per module, the topic objects (in order). Most areas show the first few
// catalog entries, while selected foundational areas are curated explicitly.
const DEFAULT_PER_TOPIC = 2;
const selectedLeanByTopic: Record<string, string[]> = {
  concentration: [
    "bernstein_sum_meas_ge_le_exp",
    "mcdiarmid_meas_ge_le_exp",
  ],
  convergence: [
    "uniform_strong_law",
    "lindeberg_feller_central_limit_theorem",
  ],
  "empirical-processes": [
    "rademacher_contraction",
    "glivenko_cantelli_quantitative",
    "dudley_entropy_integral",
  ],
  "random-variables": [
    "subexp_mgf_finite",
    "subexp_mgf_finite_of_exp_tail",
    "subexp_of_mgf_finite",
  ],
  "matrix-analysis": [
    "op_convex_mul_log",
    "hp_jensen_mul_log",
    "trace_exp_add_log_simpleFunc_jensen_posDef",
  ],
  "hd-concentration": [
    "matrix_bernstein_rect",
    "hanson_wright_isotropic",
  ],
  covariance: [
    "sampleCovariance_concentration",
    "isotropic_norm_concentration",
  ],
  "hd-geometry": [
    "subgaussian_rip_tail_anisotropic",
    "subgaussian_rip_sample_complexity",
  ],
  "nonparametric-approximation": [
    "finiteLinearSpan_classApproximationError_self_series_le_zero",
    "finiteLinearSpan_classApproximationError_le_of_pointwise_series_bound",
    "exists_sieveApproximationError_uniform_bound_of_exists_pointwise_series",
  ],
};

function selectedTheorems(topic: (typeof topics)[number]) {
  const selected = selectedLeanByTopic[topic.id];
  if (!selected) return topic.theorems.slice(0, DEFAULT_PER_TOPIC);

  const byLean = new Map(topic.theorems.map((th) => [th.lean, th]));
  return selected
    .map((lean) => byLean.get(lean))
    .filter((th): th is (typeof topic.theorems)[number] => th !== undefined);
}

const grouped = modules.map((m) => ({
  module: m,
  topics: m.topicIds
    .map((id) => topics.find((t) => t.id === id))
    .filter((t): t is (typeof topics)[number] => t !== undefined),
}));
---

<Layout title="Library" description={`Structure and selected results of ${site.name}.`}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink">Library</h1>
    <p class="mt-3 max-w-2xl text-ink-soft">
      217 Lean files, 367 theorems, and 375 supporting lemmas, organized into
      three modules (<code class="font-mono text-sm">Statlib.StatFoundation</code>,
      <code class="font-mono text-sm">Statlib.HighDim</code>, and
      <code class="font-mono text-sm">Statlib.Nonparametric</code>). Browse the full
      structure below, then a few selected results from each area.
    </p>

    <!-- Structure: complete module/file tree -->
    <div class="mt-12 flex items-baseline gap-3">
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Structure</h2>
      <span class="text-sm text-faint">— the full <code class="font-mono text-xs">Statlib/</code> tree (click to expand)</span>
    </div>
    <div class="mt-5 max-h-[28rem] overflow-auto rounded-lg border border-line bg-surface p-5">
      <TreeNode node={libraryTree} />
    </div>

    <!-- Selected results -->
    <div class="mt-16 flex items-baseline gap-3">
      <h2 class="font-serif text-2xl font-semibold tracking-tight text-ink">Selected results</h2>
      <span class="text-sm text-faint">— curated per area; see <a href="/featured" class="text-accent hover:underline">Featured</a> for deep dives</span>
    </div>

    <div class="mt-8 space-y-14">
      {
        grouped.map(({ module: m, topics: mTopics }, mi) => (
          <section id={m.id} class="scroll-mt-24">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 border-b border-line pb-3">
              <span class="font-mono text-sm text-faint">{mi + 1}</span>
              <h3 class="font-serif text-xl font-semibold text-ink">{m.title}</h3>
              <code class="font-mono text-xs text-accent">{m.lean}</code>
            </div>

            <div class="mt-6 space-y-8">
              {mTopics.map((t, ti) => (
                <section id={t.id} class="scroll-mt-24">
                  <div class="flex items-baseline gap-3">
                    <span class="font-mono text-xs text-faint">{mi + 1}.{ti + 1}</span>
                    <h4 class="font-serif text-lg font-semibold text-ink">{t.title}</h4>
                  </div>
                  <ul class="mt-3 divide-y divide-line">
                    {selectedTheorems(t).map((th) => (
                      <li class="py-4">
                        <div class="flex items-baseline gap-3">
                          <h5 class="font-medium text-ink">{th.name}</h5>
                          <span class="ml-auto">
                            <StatusBadge status={th.status} />
                          </span>
                        </div>
                        {th.latex && (
                          <div class="mt-2 overflow-x-auto text-ink">
                            <Math expr={th.latex} display />
                          </div>
                        )}
                        <p class="mt-2 text-sm text-ink-soft">{th.blurb}</p>
                        {th.lean && (
                          <code class="mt-1 block font-mono text-xs text-faint">{th.lean}</code>
                        )}
                      </li>
                    ))}
                  </ul>
                </section>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</Layout>
