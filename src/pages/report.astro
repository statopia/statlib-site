---
import Layout from "../layouts/Layout.astro";

// When the report is ready, flip this to true and fill in the links below.
const published = false;
const reportPdfUrl = "#"; // e.g. "/statlib-report.pdf" or an arXiv link
const arxivUrl = "#";
---

<Layout title="Technical Report" description="Technical report describing the statlib pipeline and results.">
  <article class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink">Technical report</h1>

    {
      published ? (
        <div class="mt-6">
          <p class="text-lg text-ink-soft">
            Read the full technical report describing the method, evaluation, and
            results behind statlib.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={reportPdfUrl}
              class="rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent/90"
            >
              Download PDF
            </a>
            <a
              href={arxivUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md border border-line bg-surface px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-accent-soft/50"
            >
              View on arXiv →
            </a>
          </div>
        </div>
      ) : (
        <div class="mt-6 rounded-lg border border-dashed border-line bg-surface p-12 text-center">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">In preparation</p>
          <h2 class="mt-3 font-serif text-2xl font-semibold text-ink">
            The technical report is on the way.
          </h2>
          <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-ink-soft">
            It will cover the formalize-and-prove pipeline, statement-integrity
            guarantees, and an evaluation of coverage across the library. Check
            back soon, or follow the repository for updates.
          </p>
        </div>
      )
    }
  </article>
</Layout>
