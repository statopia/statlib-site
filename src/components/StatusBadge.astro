---
import type { TheoremStatus } from "../data/theorems";

interface Props {
  status: TheoremStatus;
}
const { status } = Astro.props;

const map: Record<TheoremStatus, { label: string; dot: string; text: string }> = {
  proved: { label: "proved", dot: "bg-emerald-600", text: "text-emerald-700" },
  wip: { label: "in progress", dot: "bg-amber-500", text: "text-amber-700" },
  planned: { label: "planned", dot: "bg-faint", text: "text-faint" },
};
const { label, dot, text } = map[status];
---

<span class:list={["inline-flex shrink-0 items-center gap-1.5 text-xs font-medium tracking-wide", text]}>
  <span class:list={["h-1.5 w-1.5 rounded-full", dot]}></span>
  {label}
</span>
