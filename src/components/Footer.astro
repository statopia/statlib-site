---
import { site } from "../data/site";
---

<footer class="border-t border-gray-200 bg-gray-50">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-mono text-sm font-semibold text-ink">{site.org} / {site.name}</p>
      <p class="mt-1 text-sm text-ink-soft">{site.tagline}</p>
    </div>
    <div class="flex gap-6 text-sm">
      <a href={site.githubUrl} target="_blank" rel="noopener noreferrer" class="text-ink-soft hover:text-accent">
        Library repo
      </a>
      <a href="/library" class="text-ink-soft hover:text-accent">Catalog</a>
      <a href="/report" class="text-ink-soft hover:text-accent">Technical report</a>
    </div>
  </div>
</footer>
