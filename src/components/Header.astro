---
import { site } from "../data/site";

const nav = [
  { href: "/", label: "Home" },
  { href: "/library", label: "Library" },
  { href: "/graph", label: "Knowledge Graph" },
  { href: "/approach", label: "Approach" },
  { href: "/report", label: "Report" },
];

// Mark the active link based on the current path.
const here = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/85 backdrop-blur">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2.5 font-serif text-xl font-semibold tracking-tight text-ink">
      <span class="grid h-7 w-7 place-items-center rounded-sm bg-accent font-serif text-sm text-white">Σ</span>
      {site.name}
    </a>

    <div class="flex items-center gap-1">
      {
        nav.map((item) => {
          const isActive = here === (item.href === "/" ? "/" : item.href);
          return (
            <a
              href={item.href}
              class:list={[
                "rounded-md px-3 py-1.5 text-sm font-medium transition-colors",
                isActive
                  ? "bg-accent-soft text-accent"
                  : "text-ink-soft hover:bg-accent-soft/60 hover:text-ink",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
      <a
        href={site.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="ml-2 inline-flex items-center gap-1.5 rounded-md border border-line px-3 py-1.5 text-sm font-medium text-ink transition-colors hover:bg-surface"
      >
        <svg viewBox="0 0 16 16" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z" />
        </svg>
        GitHub
      </a>
    </div>
  </nav>
</header>
