---
import type { TreeNode } from "../data/tree";
import Self from "./TreeNode.astro";

interface Props {
  node: TreeNode;
  depth?: number;
}
const { node, depth = 0 } = Astro.props;
const isDir = node.dir && node.children && node.children.length > 0;
---

{
  isDir ? (
    <details open={depth < 2} class="[&>summary]:marker:text-faint">
      <summary class="cursor-pointer select-none font-mono text-sm text-accent hover:underline">
        {node.name}/
      </summary>
      <ul class="ml-3 border-l border-line pl-4">
        {node.children!.map((c) => (
          <li class="mt-0.5">
            <Self node={c} depth={depth + 1} />
          </li>
        ))}
      </ul>
    </details>
  ) : (
    <span class="font-mono text-sm text-ink-soft">{node.name}</span>
  )
}
